{
	"name": "misaf/vendra-support",
	"description": "Shared support classes for Vendra modules",
	"license": "MIT",
	"type": "vendra-module",
	"require": {
		"php": "^8.3",
		"illuminate/console": "^13.0",
		"illuminate/database": "^13.0",
		"illuminate/support": "^13.0",
		"laravel/prompts": "^0.3"
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"autoload": {
		"psr-4": {
			"Misaf\\VendraSupport\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Misaf\\VendraSupport\\Tests\\": "tests/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"Misaf\\VendraSupport\\Providers\\SupportServiceProvider"
			]
		}
	},
	"scripts": {
		"analyse": "vendor/bin/phpstan analyse",
		"format": "vendor/bin/pint",
		"test": "vendor/bin/pest",
		"test-coverage": "vendor/bin/pest --coverage"
	}
}
